---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/projects/ProjectCard.astro'
import { useTranslations } from '@/i18n'
import { LOCALES, type Lang } from '@/i18n/types'
import Layout from '@/layouts/Layout.astro'
import { getAllProjects } from '@/lib/data-utils'

export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
const projects = await getAllProjects()
const localizedProjects = projects.filter((project) => project.id.includes(locale))
const completedProjects = localizedProjects.filter((project) => project.data.isCompleted)
const uncompletedProjects = localizedProjects.filter((project) => !project.data.isCompleted)

---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'Projects', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <div class="prose mb-8">
        <p class="mb-4 text-pretty">
          {t({ 
            en: "Here are some of the projects I've worked on. (-_-)", 
            'pt-br': 'Aqui alguns dos projetos que trabalhei. (-_-)' 
          })}
        </p>
      </div>
      {uncompletedProjects.length > 0 && (
        <h2 class="mb-4 text-xl font-medium">In progress</h2>
        <div class="flex flex-col gap-4 mb-8">
          {uncompletedProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      )}
      {completedProjects.length > 0 && (
        <h2 class="mb-4 text-xl font-medium">Completed</h2>
        <div class="flex flex-col gap-4">
          {completedProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      )}
    </div>
  </section>
</Layout>
