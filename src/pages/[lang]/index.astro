---
import BlogCard from '@/components/BlogCard.astro'
import CraftCard from '@/components/CraftCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/projects/ProjectCard.astro'
import { Badge } from '@/components/ui/badge'
import { buttonVariants } from '@/components/ui/button'
import { SITE, TECHSTACK } from '@/consts'
import { useTranslations } from '@/i18n'
import { LOCALES, type Lang } from '@/i18n/types'
import Layout from '@/layouts/Layout.astro'
import { getAllCrafts, getAllPosts, getAllProjects } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { SITE_CONTENT } from '@/i18n/content'

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const projects = await getAllProjects()
const crafts = await getAllCrafts()
const blog = await getAllPosts()

const localedProjects = projects.filter((project) => project.id.includes(locale)).slice(0, SITE.featuredPostCount);
const localedCrafts = crafts.filter((craft) => craft.id.includes(locale)).slice(0, SITE.featuredCraftCount);
const localedBlog = blog.filter((post) => post.id.includes(locale)).slice(0, SITE.featuredCraftCount);

export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <section>
    <div
      class="flex flex-col-reverse gap-2 rounded-lg border sm:flex-row sm:gap-4"
    >
      <div class="flex flex-col space-y-2 p-6">
        <h3 class="text-3xl leading-none font-medium">
          {t(SITE_CONTENT.home.hero.title)}
        </h3>
        <p class="text-muted-foreground text-sm">
          {t(SITE_CONTENT.home.hero.myself_description)}
        </p>
        <p class="text-muted-foreground text-sm">
          {t(SITE_CONTENT.home.hero.description)}
        </p>
        <div class="mt-3 flex items-center gap-x-2.5">
          <Link
            href="https://github.com/cristhian-fs"
            class={buttonVariants({ variant: 'outline' })}
            external
            download
          >
            {t(SITE_CONTENT.home.hero.components.resume_button_text)}
            <Icon name="lucide:file-text" class="size-4" />
          </Link>
          <Link
            href="https://github.com/cristhian-fs"
            class={buttonVariants({ variant: 'ghost' })}
            external
          >
            <span class="sr-only">Github</span>
            <Icon name="lucide:github" class="size-4" />
          </Link>
          <Link
            href="mailto:contato@cristhianf.dev"
            class={buttonVariants({ variant: 'ghost' })}
            external
          >
            <span class="sr-only">Mail</span>
            <Icon name="lucide:mail" class="size-4" />
          </Link>
          <Link
            href="https://linkedin.com/in/cristhian-fs"
            class={buttonVariants({ variant: 'ghost' })}
            external
          >
            <span class="sr-only">Linkedin</span>
            <Icon name="lucide:linkedin" class="size-4" />
          </Link>
        </div>
      </div>
      <div class="max-h-24 w-fit max-w-24 p-1">
        <div class="size-full overflow-hidden rounded-md border shadow-sm">
          <img
            src="/mcdonalds.png"
            alt="Avatar of Cristhian"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
    <div class="mt-6 flex flex-col gap-y-2.5">
      <h3 class="text-xl font-medium">{t(SITE_CONTENT.home.techs.text)}</h3>
      <div class="flex flex-wrap items-center justify-start gap-2">
        {
          TECHSTACK.map((tech) =>
            tech.href ? (
              <Link href={tech.href} external>
                <Badge variant="outline">
                  <Icon name={tech.icon} class="size-4" />
                  {tech.name}
                </Badge>
              </Link>
            ) : (
              <Badge variant="outline">
                <Icon name={tech.icon} class="size-4" />
                {tech.name}
              </Badge>
            ),
          )
        }
      </div>
    </div>
  </section>
  <section class="mt-8 flex flex-col gap-y-4">
    <h2 class="text-xl font-medium">{t(SITE_CONTENT.home.projects.title)}</h2>
    <ul class="flex flex-col gap-4">
      {
        localedProjects.map((project) => (
          <li>
            <ProjectCard project={project} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href={getRelativeLocaleUrl(locale, "projects")}
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        {t(SITE_CONTENT.home.projects.see_all_projects_button)}
        <span class="ml-1.5 transition-transform group-hover:translate-x-1">
          &rarr;
        </span>
      </Link>
    </div>
  </section>
  <section class="mt-8 flex flex-col gap-y-4">
    <h2 class="text-xl font-medium">{t(SITE_CONTENT.home.craft.title)}</h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        localedCrafts.map((craft) => (
          <li>
            <CraftCard entry={craft} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href={getRelativeLocaleUrl(locale, "craft")}
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        {t(SITE_CONTENT.home.craft.see_all_crafts_button)}
        <span class="ml-1.5 transition-transform group-hover:translate-x-1">
          &rarr;
        </span>
      </Link>
    </div>
  </section>
  <section class="mt-8 flex flex-col gap-y-4">
    <h2 class="text-xl font-medium">{t(SITE_CONTENT.home.posts.title)}</h2>
    <ul class="flex flex-col gap-y-4">
      {
        localedBlog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href={getRelativeLocaleUrl(locale, "blog")}
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        {t(SITE_CONTENT.home.posts.see_all_posts_button)} <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>