---
import { SITE } from '@/consts'
import { ClientRouter } from 'astro:transitions'
import Favicons from './Favicons.astro'
import { DEFAULT_LOCALE  } from '@/i18n';
import { LOCALES } from '@/i18n/types';

const langs = Object.keys(LOCALES);
const baseUrl = import.meta.env.PROD ? Astro.site : "/";
const defaultLocale = DEFAULT_LOCALE;
---

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, user-scalable=yes"
  />
  <meta name="generator" content={Astro.generator} />
  <meta name="robots" content="index, follow" />

  <meta name="HandheldFriendly" content="True" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta
    name="format-detection"
    content="telephone=no,date=no,address=no,email=no,url=no"
  />

  <meta
    name="theme-color"
    content="#121212"
    media="(prefers-color-scheme: dark)"
  />
  <meta
    name="theme-color"
    content="#121212"
    media="(prefers-color-scheme: light)"
  />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="manifest" href="/site.webmanifest" />
  <link
    rel="alternate"
    type="application/rss+xml"
    title={SITE.title}
    href={new URL('rss.xml', Astro.site)}
  />

  <Favicons />
  <ClientRouter />

  <noscript>
    <meta
      http-equiv="refresh"
      content={`0;url=${baseUrl + DEFAULT_LOCALE}/`}
    />
  </noscript>

  <script is:inline define:vars={{ langs, baseUrl, defaultLocale }}>
    const currentPath = window.location.pathname;
    const currentLang = currentPath.split('/')[1]; // primeira parte após a barra

    if (!langs.includes(currentLang)) {
      // Decide o idioma
      let targetLang = defaultLocale;

      if (localStorage.selectedLang && langs.includes(localStorage.selectedLang)) {
        targetLang = localStorage.selectedLang;
      } else {
        const browserLang = navigator.language.toLowerCase();
        if (langs.includes(browserLang)) {
          targetLang = browserLang;
        } else if (langs.includes(browserLang.split("-")[0])) {
          targetLang = browserLang.split("-")[0];
        }
      }

      window.location.replace(`${baseUrl}${targetLang}/`);
    }
  </script>

  <slot />
</head>
